//---EVENT QUESTION CHAINS 

//INITIAL FENR ARGUMENT
OnQuestion.EventFenrOne1 : all
{
	"\s[0]\i[200]\i[302]\i[402]Ohhh...\w8\w8 \s[1]\i[204]\i[302]%(flail)No, no, no, it's still no good!\w8\w8 \s[1]\i[302]\i[407]Do you want to know what Fenr said to me, mortal?!\w8 Do you?!"
	"%(qprep)"
	"\![*]\_a[OnQuestion.EventFenrOne2,1]I do!\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrOne2,1]What did he say?\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrOne2,1]Seriously, what did he say\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrOne2,1]Does my answer matter here\_a"
}
OnQuestion.EventFenrOne2 : all
{
	if !reference0; silence++
	"\s[1]\i[202]\i[403]%(tears)He said to me--\w8\w8 \s[1]\i[200]\i[302]\i[407]\f[italic,1]Vala,\w8 you're STUPID for making those creatures out of membrane and tentacles and no BRAIN or CHORDS!\w8 THIS is why you're always ALONE on that QUIET, STUPID MOON OF YOURS!!\f[italic,0]\w8\w8\n\n%(s.angrytantrum)%(flail)%(tears)Does he ever SHUT UP!!\w8 I'M NOT LONELY!!\w8 IT'S HIS FAULT!!!"
	"%(qprep)"
	"\![*]\_a[OnQuestion.EventFenrOne3,1]Oh...! That's mean!\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrOne3,1]Is... Is that it?\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrOne3,1]Hasn't he done far worse\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrOne3,2]You should KILL him\_a\w8\n"
}
OnQuestion.EventFenrOne3 : all
{
	if !Flag("event.fenrone"); flags ,= "event.fenrone"
	if !reference0; silence++
	if reference0 == 2
	{
		"\s[0]\i[301]\i[403]%(tears)...\w8You know...\w8\w8 \![anim,stop,301]\i[305]I \![italic,1]should!\f[italic,0]\w8\w8 %(s.smile)Oh, mortal, you GET me--\w8\w8 "
	}
	else
	{
		"%(s.angrytantrum)%(tears)\i[407]H-H-HE...\w8\w8 \![anim,stop,407]%(flail)WAHHHHH!!\w8\w8 "
	}
	"\s[1]\i[202]\i[302]\i[403]Oh, no, that's not the POINT!\w8\w8 \s[1]\i[205]\i[302]\i[407]I've been TRYING to kill him!!\w8\w8 That's what you mortals are supposed to DO, that's why I MADE you!!\w8\w8 %(s.angrytantrum)%(flail)%(tears)Ugh, why can't you do anything right?!"
}

OnQuestion.EventFenrTwo1 : all
{
	"\s[0]\i[200]\i[301]\i[403]%(tears)...Sniffle,\w8 do you really think Fenr was right?\w8\w8 \![anim,stop,200]\i[202]I know, I know,\w8 he's a stupid brute, he's never right,\w8 but he's usually more swing than bark...\w8\w8 \s[0]\i[200]\i[301]\i[401]%(tears)And he never talks about being lonely, he's too stupid to think about things like that.\w8\w8\n\n"
	"\![anim,stop,200]\i[201]Maybe it's because he loves talking to his mortals so much.\w8\w8 So, actually, if I started to do it too..."
	"%(qprep)"
	"\![*]\_a[OnQuestion.EventFenrTwo2,1]No YOU'RE in the right\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrTwo2,1]There's a bit more to it than that\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrTwo2,1]Maybe actually listen to your subjects\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrTwo2,1]Fenr's a better Caretaker than you\_a\w8"
}
OnQuestion.EventFenrTwo2 : all 
{
	if !Flag("event.fenrtwo"); flags ,= "event.fenrtwo"
	if !reference0; silence++
	"\s[1]\i[301]\i[403]%(tears)Mmmn...\w8\w8 I just don't get it..."
}

OnQuestion.EventFenrThree1 : all 
{
	"\s[0]\i[202]\i[404]...My virtue,\w8 my commandment,\w8 is security.\w8\w8 \s[0]\i[404]As you should know,\w8 as my pitiful subject.\w8\w8 \i[202]One of the paths to assure security is to gain knowledge and seek betterment in your mind,\w8 so that you can anticipate your enemies.\w8\w8 This has nothing to do with Fenr being stupid, but my own pursuit for security.\w8\w8\n\n"
	"With that in mind...\w8\w8 \s[0]\i[304]\i[404]What does he find interesting in you mortals, anyway?"
	"%(qprep)"
	"\![*]\_a[OnQuestion.EventFenrThree2,1]Maybe he sees us as people\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrThree2,1]No, he's not too dissimilar from you treating me like a pet\_a\w8\n"
	"\![*]\_a[OnQuestion.EventFenrThree2,2]Isn't it enough to be a fun audience?\_a\w8\n"
}
OnQuestion.EventFenrThree2 : all 
{
	if !Flag("event.fenrthree"); flags ,= "event.fenrthree"
	aitalkinterval = 60
	if !reference0 
	{
		silence++
		"\s[0]\i[302]...You're supposed to SAY something, mortal.\w8\w8 \s[0]\i[303]\i[401]...Oh!\w8\w8 I think I get it now!"
	}
	elseif reference0 == 2
	{
		"\s[0]\i[303]\i[401]...\w8Oh!\w8\w8 Well,\w8 that...\w8\w8 \s[0]\i[200]\i[403]I never thought about it that way.\w8\w8 \s[0]\i[403]You...\w8\w8 \s[2]\i[403]Are \f[italic,1]fascinating,\f[italic,0]\w8 mortal."
	}
	else 
	{
		"\s[0]\i[403]Hmm...\w8\w8 There's a distinction there, I suppose.\w8\w8 \s[2]You really shouldn't concern yourself with it so much, mortal--\w8\w8 \i[301]\i[403]You're \f[italic,1]already\f[italic,0] so frail and so concerned with surviving and all."
	}
	"\w8\w8\n\n"
	"\s[2]\i[203]\i[301]\i[402]Well, it is...\w8 Nice,\w8 to have an audience.\w8\w8 I never sought one out, since you can hardly understand what I'm saying...\w8\w8 \![anim,stop,203]\i[201]But it's nice to have a listener anyway, isn't it?"
	"\w8\w8\w8\n\n"
	"\s[2]\i[403]...I like you.\w8\w8 \i[301]I've said that before, haven't I?\w8\w8 \i[203]I really do like you."
	"%(qprep)\_q"
	"(...Looks like she's finally calmed down.\w8\w8 Even if she still doesn't get it.\w8\w8 Maybe,\w8\w8 she can give you a little bit of a break on the talking.)"
}

//---INTRODUCE OTHER CARETAKERS
OnQuestion.EventCaretakersOne1 : all 
{
	"\s[0]\i[404]...I was wondering,\w8 have you met my other siblings?\w8\w8 \s[2]\i[403]Of course, I'm the only one worth visiting,\w8 but if you can visit me,\w8 you can visit the others, can't you?"
	"%(qprep)"
	"\![*]\_a[OnQuestion.EventCaretakersOne2,1]No, I haven't\_a\w8\n"
	"\![*]\_a[OnQuestion.EventCaretakersOne2,2]Didn't even know there was more than you and Fenr\_a\w8\n"
	"\![*]\_a[OnQuestion.EventCaretakersOne2,1]I'd rather not\_a\w8\n"
}
OnQuestion.EventCaretakersOne2 : all 
{
	if !reference0; silence++
	if reference0 == 2; "\s[0]\i[303]\i[401]You--!\w8\w8 \s[0]\i[301]\i[403]You didn't know?\w8\w8 Gosh, what are they teaching you mortals nowadays?\w8\w8\w8 "
	"%(s.smile)Well, you should!\w8\w8 \i[203]Visit everyone who isn't Fenr, I mean!\w8\w8 \![anim,stop,203]\i[202]All my other younger siblings,\w8 for all their disrespect,\w8 are very,\w8 very cute.\w8\w8 \s[2]\i[403]Pont's currently in it's rebellious phase, and Linlin is always so fun to have tea with!\w8\w8 \i[203]The way Linn tries to shoo me out of their workshop is so cute,\w8 they get so embarrassed around me!"
	"%(qprep)"
	"\![*]\_a[OnQuestion.EventCaretakersOne3,1]That's so cute!\_a\w8\n"
	"\![*]\_a[OnQuestion.EventCaretakersOne3,1]I'd like to meet them\_a\w8\n"
	"\![*]\_a[OnQuestion.EventCaretakersOne3,1]Sounds like they hate you\_a\w8\n"
	"\![*]\_a[OnQuestion.EventCaretakersOne3,1]Did you know you're overbearing\_a\w8"
}
OnQuestion.EventCaretakersOne3 : all 
{
	if !Flag("event.caretakersone"); flags ,= "event.caretakersone"
	if !reference0; silence++
	"%(s.smile)Ooh!\w8\w8 What if I talked about them more?\w8\w8 \i[203]You'll definitely like them too, mortal!"
	"%(qprep)\_q"
	"(...Looks like she's made up her mind about it.)"
}

