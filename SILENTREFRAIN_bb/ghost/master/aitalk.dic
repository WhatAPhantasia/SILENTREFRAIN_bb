OnWarnAnger : all
{
	"\t\*"
	random:{
		"\s[0]\i[403]...\w8You are AWFULLY quiet,\w8 aren't you.\w8\w8 You know, the whole point of entertaining you being here is because you're supposed to be COMPANY, mortal.\w8\w8 \s[1]\i[200]\i[302]Maybe start acting like it."
		"\s[0]\i[302]\i[403]...\w8Ugh.\w8\w8 You're starting to annoy me, mortal.\w8\w8 \i[200]Do you know how fun it is to talk to someone and get nothing in return?\w8\w8 \s[1]\i[302]It's not very fun at all."
		"\s[0]\i[302]...\w8Can you say something already?\w8\w8 \i[202]I loathe a silent audience.\w8\w8 \s[1]\i[302]\i[403]Do you even care?\w8 Do you?"
	}
	"%(qprep)"
	random:{
		"(She looks annoyed...)"
		"(She sounds hurt...)"
	}
}

