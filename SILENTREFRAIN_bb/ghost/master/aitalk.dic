//Written by Zichqec https://ukagaka.zichqec.com/
Capitalize
{
	_first = SUBSTR(_argv[0],0,1)
	_rest = ERASE(_argv[0],0,1) //Erase the first character and store everything else in _rest
	
	TOUPPER(_first) + _rest
}

//ANGER SILENCE LEVELS 
//making them their own block because what if i want to change the threshold for anger and force booting
anger1 {10}
anger2 {16}

//HANDLE BALLOON BREAK, TIMEOUT, AND CLOSE
ExtractNumber
{
	_expression = "\d+"
	void RE_SEARCH(_argv[0],_expression)
	RE_GETSTR[0]
}

OnBalloonBreak {"\![raise,OnNextFunc,%(oldfunc)]"}
OnBalloonClose {"\![raise,OnNextFunc,%(oldfunc)]"}
OnBalloonTimeout {"\![raise,OnNextFunc,%(oldfunc)]"}
OnChoiceTimeout {"\![raise,OnNextFunc,%(oldfunc)]"}

OnNextFunc
{
	if CHAIN.IDName == ""
	{
		//remnants of me trying to make onnextfunc work in more general contexts and replace manually typing in the event in the choice markers. alas
		//i just realllyyy dont wanna bugtest oldfunc right now
		/*
		_i = 0
		if GETTYPE(reference1) == 1; _i = reference1
		*/
		
		_num = TOINT(ExtractNumber(reference0))
		_blank = REPLACE(reference0,"%(_num)","")
		if _num == 0; _num = 2
		else; _num++
		
		_final = "%(_blank)%(_num)"
		
		if ISFUNC("%(_final)")
		{
			OnUpdateTalkInterval
			"\![raise,%(_final),%(_i)]" //lasttalk is set properly in ontranslate
		}
	}
	else;
	{
		LastTalk = ChainTalk
		LastTalk
	}
}

OnUpdateTalkInterval
{
	SHIORI3FW.ResetAITalkInterval(STRLEN("%(LastTalk)"))
	SHIORI3FW.LastTalkTime = GETSECCOUNT
}