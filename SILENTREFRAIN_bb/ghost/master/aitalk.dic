OnDressupChanged
{
	"\1\s[-1]\0%(idleneutral)"
	--
	if !Flag("firstboot") {OnFirstBoot}
	else
	{
		if reference1 == "Transparent Blue"
		{
			if reference2; "\s[2]\i[403]Hummm...\w8\w8 Yes, I think I like this.\w8\w8 \i[203]It's my favorite dress, you know."
			else; "\s[0]\i[403]Hm...\w8\w8 It's getting in the way.\w8\w8 \s[0]\i[202]I'm done with that for now!"
		}
	}
}

