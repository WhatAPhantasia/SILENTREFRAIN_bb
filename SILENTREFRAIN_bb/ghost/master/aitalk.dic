}

OnQuestion.HarpsFav : all
{
	"\s[0]\i[202]Strings connect your entire world, my entire being, the Bramblebrush and beyond...\w8\w8 \i[404]Knowing this, I made the harp, and gifted it to my first subjects.\w8\w8 %(s.smile)You've all made such pretty harps from then on!\w8\w8 Creature-string, metal, Resonance-encrusted...\w8\w8 You like harps too, right, mortal?"
	"%(qprep)"
	"\![*]\_a[OnQuestion.HarpsFav2,1]Never thought about it before\_a\w8\n"
	"\![*]\_a[OnQuestion.HarpsFav2,1]They're so peaceful\_a\w8\n"
	"\![*]\_a[OnQuestion.HarpsFav2,1]They look hard to play\_a\w8\n"
	"\![*]\_a[OnQuestion.HarpsFav2,1]I hate them\_a\w8\n"
}
